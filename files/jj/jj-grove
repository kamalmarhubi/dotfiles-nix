#!/usr/bin/env python3
"""jj-grove: manage groves and their workspaces.

A "grove" is a long-lived line of work rooted at an empty base commit on
trunk(), bookmarked `kamal/<slug>/base`, with one or more jj workspaces bound to
it via per-workspace config (`grove_base()` / `grove_bookmarks()`). The revset
machinery (grove_base/grove_bases/grove_bookmarks/grove/is_grove_base)
lives in jj's config.toml; this script is the front door for creating and
managing groves.

Subcommands:
  new <slug> [--bare] [--root DIR]   create a grove (+ a workspace unless --bare)
  workspace add <slug> <name> [--root DIR]
                                      add another workspace to an existing grove
  use <slug>                         bind the current workspace to an existing grove
  list                               list groves and their workspaces
  rm <slug> [--force]                remove a grove (its workspaces + base bookmark)
  graft <revset> [--push]            graduate a rooted prefix onto trunk as bookmarks to push
  sync [--no-fetch] [--keep-merged]  advance the base onto trunk; prune merged bookmarks
  restack [revset] [--push]          rebase grove bookmarks onto trunk (default: all)
  push                               push the grove's bookmarks to the remote

Output contract: the new workspace's absolute path goes to stdout
(new/workspace add); all human narration goes to stderr; -q/--quiet drops the
narration. -n/--dry-run prints the plan without touching anything.
"""

from __future__ import annotations

import argparse
import functools
import os
import re
import shutil
import subprocess
import sys

GROVE_BASE_SUFFIX = "base"
GROVE_BASE_ALIAS = 'revset-aliases."grove_base()"'
GROVE_BOOKMARKS_ALIAS = 'revset-aliases."grove_bookmarks()"'
GROVE_BASE_REVSET = "grove_base()"
GROVE_BASES_REVSET = "grove_bases()"
GROVE_BOOKMARKS_REVSET = "grove_bookmarks()"


@functools.cache
def grove_prefix() -> str:
    return jj("config", "get", 'revset-aliases."grove_prefix()"').strip('"')


def grove_base_bookmark(slug: str) -> str:
    return f"{grove_prefix()}{slug}/{GROVE_BASE_SUFFIX}"


def grove_bookmark_glob(slug: str) -> str:
    return f"{grove_prefix()}{slug}/*"


def bookmarks_value(slug: str) -> str:
    return f'grove_bookmarks("{grove_bookmark_glob(slug)}")'


# --------------------------------------------------------------------------- #
# output
# --------------------------------------------------------------------------- #

QUIET = False
DRY = False


def info(msg: str = "") -> None:
    if not QUIET:
        print(msg, file=sys.stderr)


def plan(msg: str) -> None:
    # always shown, even with --quiet: the plan IS the output
    print(f"  {msg}", file=sys.stderr)


def die(msg: str, code: int = 1) -> "None":
    print(f"jj grove: {msg}", file=sys.stderr)
    sys.exit(code)


# --------------------------------------------------------------------------- #
# jj helpers
# --------------------------------------------------------------------------- #


def jj(*args: str, cwd: str | None = None) -> str:
    """Run a read-only jj query; return stripped stdout."""
    r = subprocess.run(
        ["jj", *args], cwd=cwd, text=True,
        stdout=subprocess.PIPE, stderr=subprocess.PIPE,
    )
    if r.returncode != 0:
        die(f"`jj {' '.join(args)}` failed:\n{r.stderr.strip()}")
    return r.stdout.strip()


def do(*args: str, cwd: str | None = None, why: str = "") -> None:
    """Run a mutating jj command. Honors --dry-run."""
    if DRY:
        plan("jj " + " ".join(args) + (f"   # {why}" if why else ""))
        return
    r = subprocess.run(["jj", "--quiet", *args], cwd=cwd, text=True,
                       stderr=subprocess.PIPE)
    if r.returncode != 0:
        die(f"`jj {' '.join(args)}` failed:\n{r.stderr.strip()}")


def do_fs(desc: str, fn) -> None:
    """Run a filesystem mutation. Honors --dry-run."""
    if DRY:
        plan(desc)
        return
    fn()


@functools.cache
def push_remote() -> str:
    """The remote `jj git push` targets: git.push, else the sole remote, else origin."""
    r = subprocess.run(["jj", "config", "get", "git.push"], text=True,
                       stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
    if r.returncode == 0 and r.stdout.strip():
        return r.stdout.strip()
    remotes = [ln.split()[0] for ln in jj("git", "remote", "list").splitlines() if ln.strip()]
    return remotes[0] if len(remotes) == 1 else "origin"


def has_remote() -> bool:
    return bool(jj("git", "remote", "list").strip())


# --------------------------------------------------------------------------- #
# grove / workspace queries
# --------------------------------------------------------------------------- #


def current_ws_root() -> str:
    return jj("workspace", "root")


def siblings_parent() -> str:
    # where new workspace dirs go: sibling of the current workspace root
    return os.path.dirname(current_ws_root())


def grove_exists(slug: str) -> bool:
    out = jj(
        "log",
        "--no-graph",
        "-r",
        f"present({grove_base_bookmark(slug)})",
        "-T",
        '"x"',
    )
    return bool(out)


def at_on_base(slug: str, cwd: str | None = None) -> bool:
    # is @ a descendant of (or equal to) the grove base?
    out = jj(
        "log",
        "--no-graph",
        "-r",
        f"@ & descendants(present({grove_base_bookmark(slug)}))",
        "-T",
        '"x"',
        cwd=cwd,
    )
    return bool(out)


def binding_slug(cwd: str | None = None) -> str | None:
    """The grove a workspace is bound to (its grove_base() override), or None."""
    val = jj("config", "get", GROVE_BASE_ALIAS, cwd=cwd)
    return slug_of(val)


def bound_slug() -> str:
    slug = binding_slug()
    if slug is None:
        die(
            f"not bound to a grove ({GROVE_BASE_REVSET} is none()); "
            "cd into a grove workspace."
        )
    return slug


def slug_of(base_value: str) -> str | None:
    m = re.fullmatch(
        rf"{re.escape(grove_prefix())}(?P<slug>[^/]+)/{re.escape(GROVE_BASE_SUFFIX)}",
        base_value,
    )
    return m["slug"] if m else None


def workspaces() -> list[tuple[str, str]]:
    out = jj("workspace", "list", "-T", 'name ++ "\t" ++ root ++ "\n"')
    pairs = []
    for line in out.splitlines():
        if "\t" in line:
            name, root = line.split("\t", 1)
            pairs.append((name, root))
    return pairs


def validate_slug(slug: str, what: str = "grove name") -> None:
    if not slug or "/" in slug:
        die(f"invalid {what}: {slug!r} (must be non-empty and contain no '/')")


# --------------------------------------------------------------------------- #
# bind
# --------------------------------------------------------------------------- #


def bind(slug: str, cwd: str | None = None) -> None:
    do(
        "config",
        "set",
        "--workspace",
        GROVE_BASE_ALIAS,
        grove_base_bookmark(slug),
        cwd=cwd,
        why=f"bind {GROVE_BASE_REVSET}",
    )
    do(
        "config",
        "set",
        "--workspace",
        GROVE_BOOKMARKS_ALIAS,
        bookmarks_value(slug),
        cwd=cwd,
        why="bind grove_bookmarks()",
    )


# --------------------------------------------------------------------------- #
# subcommands
# --------------------------------------------------------------------------- #


def cmd_new(args) -> None:
    slug = args.slug
    validate_slug(slug)
    if grove_exists(slug):
        die(f"grove '{slug}' already exists. "
            f"Use `jj grove workspace add {slug} <name>` to add a workspace.")

    base = grove_base_bookmark(slug)
    if args.bare:
        info(f"creating grove '{slug}' (base only) at {base}")
        if DRY:
            plan(
                f"jj new --no-edit trunk() -m {slug + ' base'!r}"
                "   # create base commit"
            )
            plan(f"jj bookmark create {base} -r <new commit>")
            return
        r = subprocess.run(
            ["jj", "new", "--no-edit", "trunk()", "-m", f"{slug} base"],
            text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
        )
        if r.returncode != 0:
            die(f"creating base commit failed:\n{r.stderr.strip()}")
        m = re.search(r"Created new commit (\S+)", r.stderr)
        if not m:
            die(f"couldn't find new commit id in:\n{r.stderr.strip()}")
        do("bookmark", "create", base, "-r", m.group(1), why="bookmark base")
        info(f"created grove '{slug}' (no workspace)")
        return

    dest = os.path.abspath(args.root or os.path.join(siblings_parent(), slug))
    name = os.path.basename(dest)
    info(f"creating grove '{slug}' + workspace '{name}' at {dest}")
    parent = os.path.dirname(dest)
    do_fs(f"mkdir -p {parent}", lambda: os.makedirs(parent, exist_ok=True))
    do(
        "workspace",
        "add",
        "-r",
        "trunk()",
        dest,
        "--name",
        name,
        why="new workspace on trunk",
    )
    do("describe", "-m", f"{slug} base", cwd=dest, why="describe base")
    do("bookmark", "create", base, "-r", "@", cwd=dest, why="bookmark base")
    do("new", cwd=dest, why="working commit on base")
    bind(slug, cwd=dest)
    info(f"created grove '{slug}'; workspace at {dest}")
    if not DRY:
        print(dest)


def cmd_workspace_add(args) -> None:
    slug, name = args.slug, args.name
    validate_slug(slug)
    validate_slug(name, "workspace name")
    if not grove_exists(slug):
        die(f"no grove '{slug}'. Use `jj grove new {slug}` to create it.")

    dest = os.path.abspath(
        args.root or os.path.join(siblings_parent(), f"{slug}-{name}")
    )
    wsname = os.path.basename(dest)
    info(f"adding workspace '{wsname}' on grove '{slug}' at {dest}")
    parent = os.path.dirname(dest)
    do_fs(f"mkdir -p {parent}", lambda: os.makedirs(parent, exist_ok=True))
    base = grove_base_bookmark(slug)
    do(
        "workspace",
        "add",
        "-r",
        base,
        dest,
        "--name",
        wsname,
        why="new workspace on grove base",
    )
    bind(slug, cwd=dest)
    info(f"added workspace '{wsname}' on grove '{slug}'")
    if not DRY:
        print(dest)


def cmd_use(args) -> None:
    slug = args.slug
    validate_slug(slug)
    if not grove_exists(slug):
        die(f"no grove '{slug}'. Use `jj grove new {slug}` to create it.")

    current = binding_slug()
    if current == slug:
        info(f"already on grove '{slug}'")
        return
    base = grove_base_bookmark(slug)
    if not at_on_base(slug):
        if current is not None:
            die(f"@ isn't on {base}, and this workspace is bound to "
                f"grove '{current}'; use won't rebase across groves.\n"
                f"       move @ yourself:  jj rebase -b @ -d {base}\n"
                f"       then re-run:      jj grove use {slug}")
        if not args.rebase:
            die(f"@ isn't on {base} -- the grove log won't include "
                f"your work.\n"
                f"       move it there:  jj rebase -b @ -d {base}\n"
                f"       or re-run with: jj grove use {slug} --rebase")
        do("rebase", "-b", "@", "-d", base, why="rebase @ onto base")
    bind(slug)
    if current:
        info(f"rebound grove '{current}' -> '{slug}'")
    else:
        info(f"bound current workspace to grove '{slug}'")


def cmd_list(args) -> None:
    bases = jj(
        "log", "--no-graph", "-r", GROVE_BASES_REVSET, "-T", 'bookmarks ++ "\n"'
    )
    slugs = sorted(filter(None, (slug_of(b.strip()) for b in bases.splitlines())))

    cur_slug = binding_slug()
    cur_root = os.path.realpath(current_ws_root())

    by_slug: dict[str, list[str]] = {s: [] for s in slugs}
    for name, root in workspaces():
        s = binding_slug(cwd=root)
        if s in by_slug:
            mark = " (here)" if os.path.realpath(root) == cur_root else ""
            by_slug[s].append(name + mark)

    if not slugs:
        info("no groves")
        return

    for s in slugs:
        base = grove_base_bookmark(s)
        # stale: no live mutable work and no unmerged pushed bookmarks
        live = jj(
            "log",
            "--no-graph",
            "-r",
            f"(descendants({base}) & mutable()) ~ {base}",
            "-T",
            '"x"',
        )
        unmerged = jj(
            "log",
            "--no-graph",
            "-r",
            f'(bookmarks(glob:"{grove_bookmark_glob(s)}") ~ {base}) ~ ::trunk()',
            "-T",
            '"x"',
        )
        flags = []
        if s == cur_slug:
            flags.append("current")
        if not live and not unmerged:
            flags.append("stale")
        tag = f"  [{', '.join(flags)}]" if flags else ""
        ws = ", ".join(by_slug[s]) or "-"
        print(f"{s:<20} {base:<26} ws: {ws}{tag}")


def cmd_rm(args) -> None:
    slug = args.slug
    validate_slug(slug)
    if not grove_exists(slug):
        die(f"no grove '{slug}'.")

    base = grove_base_bookmark(slug)
    cur_root = os.path.realpath(current_ws_root())
    bound = [
        (name, root) for name, root in workspaces() if binding_slug(cwd=root) == slug
    ]

    # guard: don't pull the rug out from under the current workspace
    for name, root in bound:
        if os.path.realpath(root) == cur_root:
            die(f"you're inside grove '{slug}' (workspace '{name}'). "
                f"cd to a workspace outside it and re-run.")

    # guard: refuse if any bound workspace has non-empty (would-be-lost) work
    if not args.force:
        risky = jj(
            "log",
            "--no-graph",
            "-r",
            f"(descendants({base}) & mutable()) ~ empty()",
            "-T",
            '"x"',
        )
        if risky:
            die(f"grove '{slug}' has non-empty local commits that would be lost. "
                f"Re-run with --force to remove anyway.")

    info(f"removing grove '{slug}':")
    info(f"  bookmark  {base}")
    for name, root in bound:
        info(f"  workspace {name}  ({root})")
    if not bound:
        info("  (no bound workspaces)")

    if DRY:
        plan(
            f"jj workspace forget {' '.join(n for n, _ in bound)}"
            if bound
            else "(nothing to forget)"
        )
        for _, root in bound:
            plan(f"rm -rf {root}")
        plan(f"jj bookmark delete {base}")
        return

    if not args.force:
        if not sys.stdin.isatty():
            die("refusing to remove without confirmation (not a TTY); use --force")
        try:
            ans = input("delete these workspaces and the base? [y/N] ")
        except EOFError:
            ans = ""
        if ans.strip().lower() not in ("y", "yes"):
            die("aborted", code=1)

    if bound:
        do("workspace", "forget", *[n for n, _ in bound], why="forget workspaces")
    for _, root in bound:
        do_fs(f"rm -rf {root}", lambda root=root: shutil.rmtree(root, ignore_errors=True))
    do("bookmark", "delete", base, why="delete base bookmark")
    info(f"removed grove '{slug}'")


# --------------------------------------------------------------------------- #
# graft
# --------------------------------------------------------------------------- #


def _ids(revset: str) -> list[str]:
    """Unambiguous short change-ids for a revset (stable across rebase)."""
    out = jj("log", "--no-graph", "-r", revset, "-T", 'change_id.shortest(8) ++ "\n"')
    return [c for c in out.splitlines() if c]


def graft_selection_revset(user_revset: str) -> str:
    return f"(({user_revset}) & ({GROVE_BASE_REVSET}..))"


def graft_prefix_revset(selection_heads: str) -> str:
    return f"(({GROVE_BASE_REVSET}..{selection_heads}) ~ ::{GROVE_BOOKMARKS_REVSET})"


def graft_survivors_revset(selection_heads: str) -> str:
    return f"children({selection_heads}) ~ ({GROVE_BASE_REVSET}..{selection_heads})"


def merged_grove_bookmarks_revset(slug: str) -> str:
    return (
        f'bookmarks(glob:"{grove_bookmark_glob(slug)}") '
        f"& (::trunk() ~ {GROVE_BASES_REVSET})"
    )


def cmd_graft(args) -> None:
    revset = args.revset
    slug = bound_slug()

    S = graft_selection_revset(revset)            # commits to bookmark
    heads_S = f"heads({S})"
    newwork = graft_prefix_revset(heads_S)
    fork = f"fork_point({GROVE_BASE_REVSET} | trunk())"

    # guards: all before mutating
    if jj("log", "--no-graph", "-r", f"{GROVE_BASE_REVSET} & ~empty()", "-T", '"x"'):
        die("grove base is not empty (NONEMPTY-BASE); graft would drop its changes.")
    stray = _ids(f"(({revset}) & mutable()) ~ grove()")
    if stray:
        die(f"revset reaches outside the grove: {', '.join(stray)}")
    if not _ids(S):
        die("nothing to graft (revset matches no grove work above the base).")
    bad = _ids(f"({newwork}) & (incomplete() | conflicts())")
    if bad:
        die(f"range has WIP/conflicted commits; finish them first: {', '.join(bad)}")

    info(f"grafting '{revset}' onto trunk")
    start_op = jj("op", "log", "-n1", "--no-graph", "-T", "self.id()")
    names: list[str] = []
    try:
        # lift: re-root not-yet-grafted work onto its non-base parent, else the fork point
        for r in _ids(f"roots({newwork})"):
            onto = _ids(f"parents({r}) ~ {GROVE_BASE_REVSET}")
            dest = " | ".join(onto) if onto else fork
            do("rebase", "-s", r, "--onto", dest, why=f"lift {r}")
        # reconnect: survivors above the cut gain the base as an extra parent
        for c in _ids(graft_survivors_revset(heads_S)):
            do("rebase", "-r", c, "--onto", f"(parents({c})) | {GROVE_BASE_REVSET}",
               why=f"reconnect {c} to base")
        # bookmark each grafted commit
        rows = jj("log", "--no-graph", "--reversed", "-r", S, "-T",
                  'change_id.shortest(8) ++ "\t"'
                  ' ++ author.timestamp().local().format("%Y-%m-%d") ++ "-" ++ change_id.short()'
                  ' ++ "\n"')
        for line in rows.splitlines():
            if "\t" not in line:
                continue
            cid, suffix = line.split("\t", 1)
            name = f"{grove_prefix()}{slug}/{suffix}"
            do("bookmark", "create", name, "-r", cid, why="bookmark")
            names.append(name)
    except SystemExit:
        if not DRY:
            rb = subprocess.run(["jj", "--quiet", "op", "restore", start_op],
                                text=True, stderr=subprocess.PIPE)
            if rb.returncode == 0:
                info("rolled back; nothing changed.")
            else:
                info(f"rollback FAILED -- restore by hand:  jj op restore {start_op}")
        raise

    info(f"grafted {len(names)} bookmark(s)" + ("" if args.push else " (local; not pushed)"))

    # track to the push remote so a hand `jj git push -r <rev>` works later;
    # best-effort and offline-safe -- graft itself needs no remote
    if names and has_remote():
        _track(names)

    if args.push:
        _push(names, why="push grafted bookmarks")

    if not DRY:
        for name in names:
            print(name)


# --------------------------------------------------------------------------- #
# sync
# --------------------------------------------------------------------------- #


def cmd_sync(args) -> None:
    slug = bound_slug()

    # refuse if a grove bookmark sits on a base-descendant: advancing the base
    # would rebase a live pushed bookmark
    onbase = _ids(f"{GROVE_BOOKMARKS_REVSET} & descendants({GROVE_BASE_REVSET})")
    if onbase:
        die(f"grove bookmark(s) sit on base-descendants; sync would rebase them: "
            f"{', '.join(onbase)}")

    if not args.no_fetch:
        if DRY:
            plan("jj git fetch")
        else:
            info("fetching...")
            r = subprocess.run(["jj", "git", "fetch"], text=True, stderr=subprocess.PIPE)
            if r.returncode != 0:
                die(f"fetch failed:\n{r.stderr.strip()}\n"
                    f"       use --no-fetch to advance onto the local trunk.")

    info(f"syncing grove '{slug}' onto trunk")
    start_op = jj("op", "log", "-n1", "--no-graph", "-T", "self.id()")
    merged: list[str] = []
    try:
        # advance the base (+ on-base survivors) onto current trunk; --simplify-parents
        # drops now-redundant parent edges to merged grafts. -s grove_base() scopes the
        # rebase to base + descendants, so off-base bookmarks are left untouched.
        do("rebase", "-s", GROVE_BASE_REVSET, "--onto", "trunk()", "--simplify-parents",
           why="advance base onto trunk")
        # prune merged grove bookmarks; `delete` removes their remote branches on
        # the next push (--keep-merged skips)
        if not args.keep_merged:
            merged = jj(
                "bookmark", "list", "-r", merged_grove_bookmarks_revset(slug),
                "-T", 'if(!remote && present && !conflict, name ++ "\n")'
            ).splitlines()
            if merged:
                do("bookmark", "delete", *merged, why="prune merged")
    except SystemExit:
        if not DRY:
            rb = subprocess.run(["jj", "--quiet", "op", "restore", start_op],
                                text=True, stderr=subprocess.PIPE)
            if rb.returncode == 0:
                info("rolled back; nothing changed.")
            else:
                info(f"rollback FAILED -- restore by hand:  jj op restore {start_op}")
        raise

    info(f"synced onto trunk{f'; pruned {len(merged)} merged bookmark(s) '
         f'(remote branches deleted on next push)' if merged else ''}")


# --------------------------------------------------------------------------- #
# push
# --------------------------------------------------------------------------- #


def _track(names: list[str]) -> None:
    """Best-effort: track bookmarks to the push remote so a hand `jj git push -r
    <rev>` works later. Failures are ignored (e.g. no remote)."""
    remote = push_remote()
    if DRY:
        plan(f"jj bookmark track {' '.join(names)} --remote {remote}")
        return
    subprocess.run(["jj", "--quiet", "bookmark", "track", *names, "--remote", remote],
                   text=True, stderr=subprocess.DEVNULL)


def _push(names: list[str], why: str = "") -> None:
    """Push bookmarks by name to the push remote. `-b <name>` auto-tracks/creates
    new bookmarks and force-with-lease updates moved ones. jj's output (progress,
    remote branch URLs) flows to the terminal. Honors --dry-run / --quiet."""
    remote = push_remote()
    flags = [a for name in names for a in ("-b", name)]
    if DRY:
        plan(f"jj git push --remote {remote} {' '.join(flags)}"
             + (f"   # {why}" if why else ""))
        return
    cmd = ["jj", "git", "push", "--remote", remote, *flags]
    if QUIET:
        cmd.insert(1, "--quiet")
    if subprocess.run(cmd, text=True).returncode != 0:
        die("push failed (see above); bookmarks remain tracked locally -- "
            "fix the cause and re-run.")


def cmd_push(args) -> None:
    slug = bound_slug()

    base = grove_base_bookmark(slug)
    glob = f"glob:{grove_bookmark_glob(slug)}"
    remote = push_remote()

    # live bookmarks: present locally under the grove glob.
    live = jj("bookmark", "list", glob,
              "-T", 'if(!remote && present, name ++ "\n")').splitlines()
    # merged-bookmark deletions: locally deleted, still on the push remote
    # (sync deletes them locally; this flushes the removal to the remote).
    # --remote scopes to the push remote (and excludes any colocated `git`
    # remote); `tracked` drops the local-only entry --remote also surfaces.
    gone = jj("bookmark", "list", "--remote", remote, glob,
              "-T", 'if(tracked && present && !tracking_present, name ++ "\n")').splitlines()
    live = {n for n in live if n and n != base}
    gone = {n for n in gone if n and n != base}
    names = sorted(live | gone)
    if not names:
        info(f"nothing to push for grove '{slug}'")
        return

    info(f"pushing grove '{slug}'")
    _push(names, why="push grove bookmarks; flush merged deletions")
    if not DRY:
        summary = []
        if live:
            summary.append(f"pushed {len(live)} bookmark(s)")
        if gone:
            summary.append(f"deleted {len(gone)} remote branch(es)")
        info("; ".join(summary))


# --------------------------------------------------------------------------- #
# restack
# --------------------------------------------------------------------------- #


def cmd_restack(args) -> None:
    slug = bound_slug()

    # the revset (default all()) scopes which bookmarks to rebase, intersected
    # with grove_bookmarks() so it can never reach non-grove work.
    sel = f"{GROVE_BOOKMARKS_REVSET} & ({args.revset})"
    selected = _ids(sel)
    if not selected:
        info(f"nothing to restack for grove '{slug}'")
        return
    # `-b` rebases whole branches, so a selected bookmark pulls the rest of its
    # stack along. capture both sets as change-ids (stable across the rebase) so
    # the post-rebase reasoning holds even for a commit-hash revset.
    moved = _ids(f"{GROVE_BOOKMARKS_REVSET} & reachable(({sel}), mutable())")

    # rebase the selected branches onto current trunk. jj records any conflicts
    # rather than failing, so this won't abort mid-way.
    info(f"restacking grove '{slug}' onto trunk")
    do("rebase", "-b", sel, "-d", "trunk()", why="rebase bookmarks onto trunk")

    movedset, selectedset = " | ".join(moved), " | ".join(selected)
    conflicted = _ids(f"({movedset}) & conflicts()")
    if conflicted:
        info(f"WARNING: {len(conflicted)} bookmark(s) now conflict with trunk: "
             f"{', '.join(conflicted)}")

    if not args.push:
        if not DRY:
            info("restacked locally; run `jj grove push` to update the remotes")
        return

    # push only the selected bookmarks, even though the whole stack moved;
    # `_push`'s `-b <name>` force-with-lease updates them. conflicted ones
    # can't push.
    pushed = sorted(
        n for n in jj("bookmark", "list", "-r", f"({selectedset}) ~ conflicts()",
                      "-T", 'if(!remote, name ++ "\n")').splitlines()
        if n
    )
    if pushed:
        _push(pushed, why="push restacked bookmarks")

    # the rest of the stack moved locally but wasn't pushed (not named); flag it
    # so the remote drift isn't silent.
    extra = sorted(
        n for n in jj("bookmark", "list", "-r", f"({movedset}) ~ conflicts()",
                      "-T", 'if(!remote, name ++ "\n")').splitlines()
        if n and n not in set(pushed)
    )
    if extra:
        info(f"note: {len(extra)} restacked bookmark(s) changed but not pushed: "
             f"{', '.join(extra)} (run `jj grove push` to update them)")


# --------------------------------------------------------------------------- #
# cli
# --------------------------------------------------------------------------- #


def main() -> None:
    global QUIET, DRY

    p = argparse.ArgumentParser(prog="jj grove", description="manage groves and their workspaces")
    sub = p.add_subparsers(dest="cmd", required=True)

    common = argparse.ArgumentParser(add_help=False)
    common.add_argument("-q", "--quiet", action="store_true", help="suppress narration (stderr)")
    common.add_argument("-n", "--dry-run", action="store_true", help="print the plan; change nothing")
    p.set_defaults(quiet=False, dry_run=False)  # for verbs without common (list)

    sp = sub.add_parser("new", parents=[common], help="create a grove (+ a workspace unless --bare)")
    sp.add_argument("slug")
    sp.add_argument("--bare", action="store_true", help="create the base only, no workspace")
    sp.add_argument("--root", metavar="DIR", help="workspace directory (default: ../<slug>)")
    sp.set_defaults(fn=cmd_new)

    sp = sub.add_parser("workspace", help="manage grove workspaces")
    workspace_sub = sp.add_subparsers(dest="workspace_cmd", required=True)

    sp = workspace_sub.add_parser("add", parents=[common], help="add a workspace to an existing grove")
    sp.add_argument("slug")
    sp.add_argument("name")
    sp.add_argument("--root", metavar="DIR", help="workspace directory (default: ../<slug>-<name>)")
    sp.set_defaults(fn=cmd_workspace_add)

    sp = sub.add_parser("use", parents=[common], help="bind the current workspace to an existing grove")
    sp.add_argument("slug")
    sp.add_argument("--rebase", action="store_true",
                    help="if unbound and @ is off-base, rebase @ onto the base first")
    sp.set_defaults(fn=cmd_use)

    sp = sub.add_parser("list", help="list groves and their workspaces")
    sp.set_defaults(fn=cmd_list)

    sp = sub.add_parser("rm", parents=[common], help="remove a grove (workspaces + base bookmark)")
    sp.add_argument("slug")
    sp.add_argument("--force", action="store_true", help="skip guards and confirmation")
    sp.set_defaults(fn=cmd_rm)

    sp = sub.add_parser("graft", parents=[common], help="graduate a rooted prefix onto trunk as bookmarks to push")
    sp.add_argument("--push", action="store_true", help="also push the bookmarks to the remote")
    sp.add_argument("revset", help="commits to bookmark; the prefix below them is grafted")
    sp.set_defaults(fn=cmd_graft)

    sp = sub.add_parser("sync", parents=[common], help="advance the grove base onto trunk; prune merged bookmarks")
    sp.add_argument("--no-fetch", action="store_true",
                    help="skip the git fetch; advance onto the local trunk")
    sp.add_argument("--keep-merged", action="store_true",
                    help="don't prune merged bookmarks (default deletes them; remote branch removed on next push)")
    sp.set_defaults(fn=cmd_sync)

    sp = sub.add_parser("restack", parents=[common], help="rebase grove bookmarks onto trunk")
    sp.add_argument("--push", action="store_true", help="also push the rebased bookmarks")
    sp.add_argument("revset", nargs="?", default="all()", help="bookmarks to rebase (default: all grove bookmarks)")
    sp.set_defaults(fn=cmd_restack)

    sp = sub.add_parser("push", parents=[common], help="push the grove's bookmarks to the remote")
    sp.set_defaults(fn=cmd_push)

    args = p.parse_args()
    QUIET = args.quiet
    DRY = args.dry_run
    args.fn(args)


if __name__ == "__main__":
    main()
